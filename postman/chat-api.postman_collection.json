{
  "info": {
    "_postman_id": "5b8a8c70-3a1e-4b71-9d20-2b6d1f8a91e2",
    "name": "Realtime Chat (Laravel + Reverb)",
    "description": "End-to-end Postman collection for the Sanctum-auth realtime chat API.\n\nUsage:\n1. Run `Auth › Register` — the test script saves the returned token into the `auth_token` collection variable.\n2. Run any other endpoint — the Authorization header is auto-injected.\n3. Run `Chat Rooms › Create Room` — its test script saves `chat_room_id`.\n4. Run `Messages › Send Message` etc.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000", "type": "string" },
    { "key": "auth_token", "value": "", "type": "string" },
    { "key": "chat_room_id", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{auth_token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('auth_token', json.token); }",
                  "pm.test('201 created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\",\n  \"device\": \"postman\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('auth_token', json.token); }",
                  "pm.test('200 ok', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/logout"
          }
        }
      ]
    },
    {
      "name": "Chat Rooms",
      "item": [
        {
          "name": "List Rooms",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/chat-rooms"
          }
        },
        {
          "name": "Create Room",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/chat-rooms",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"General\",\n  \"description\": \"Public watercooler\",\n  \"type\": \"public\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.collectionVariables.set('chat_room_id', json.data.id); }",
                  "pm.test('201 created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "Show Room",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/chat-rooms/{{chat_room_id}}"
          }
        },
        {
          "name": "Join Room",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/chat-rooms/{{chat_room_id}}/join"
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "List Messages",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/chat-rooms/{{chat_room_id}}/messages?per_page=30"
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/chat-rooms/{{chat_room_id}}/messages",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Hello, realtime world!\"\n}"
            }
          }
        },
        {
          "name": "Typing Indicator",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/chat-rooms/{{chat_room_id}}/typing",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_typing\": true\n}"
            }
          }
        }
      ]
    }
  ]
}
