{
  "info": {
    "_postman_id": "b2e9b0b7-9a66-4b75-9cfe-7a4c0c9c9e9b",
    "name": "learn-web-socket",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "orderId",
      "value": "1"
    },
    {
      "key": "email",
      "value": "test@example.com"
    },
    {
      "key": "password",
      "value": "password"
    }
  ],
  "item": [
    {
      "name": "Web (views / session auth)",
      "item": [
        {
          "name": "Home (GET /)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            }
          }
        },
        {
          "name": "Login page (GET /login)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            }
          }
        },
        {
          "name": "Login (POST /login)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            }
          }
        },
        {
          "name": "Orders page (GET /orders)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            }
          }
        },
        {
          "name": "Order show (GET /orders/{id}) [auth middleware]",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderId}}"]
            }
          }
        },
        {
          "name": "Order update (GET /orders/update/{id}) [auth middleware]",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders/update/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "update", "{{orderId}}"]
            }
          }
        },
        {
          "name": "Dashboard (GET /dashboard) [auth middleware]",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard"]
            }
          }
        }
      ]
    },
    {
      "name": "API v1 (JSON)",
      "item": [
        {
          "name": "List orders (GET /api/v1/orders)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "orders"]
            }
          }
        },
        {
          "name": "Get order (GET /api/v1/orders/{id})",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "orders", "{{orderId}}"]
            }
          }
        },
        {
          "name": "Increment order (POST /api/v1/orders/{id}/increment)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/increment",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "orders", "{{orderId}}", "increment"]
            }
          }
        }
      ]
    }
  ]
}

